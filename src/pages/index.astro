  }

  .stats-table .metric-label {
    text-align: center;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-faint);
  }

  .stats-table .value {
    width: 32%;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    text-align: center;
  }

  .stats-table .value.leading {
