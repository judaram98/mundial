    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .chip.verdict-hit {
    border-color: rgba(110, 231, 183, 0.5);
    background: rgba(110, 231, 183, 0.07);
    color: rgba(170, 255, 210, 0.95);
  }

  .chip.verdict-miss {
    border-color: rgba(255, 150, 140, 0.5);
    background: rgba(255, 140, 130, 0.06);
    color: rgba(255, 180, 170, 0.95);
  }

  .ia-predicted {
    font-size: 0.78rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.04em;
    color: var(--text-faint);
  }

  @media (max-width: 640px) {
    .matchup-header {
      grid-template-columns: 1fr auto 1fr;
      gap: 0.5rem;
    }
    
    .flag-large, .flag-placeholder {
      width: 56px;
      height: 56px;
    }
    
    .team-side h3 {
      font-size: 0.85rem;
    }

    .predicted-score {
      font-size: 2rem;
    }
  }
</style>

<script>
  import { getFlagUrl } from '../lib/flags';
  import { stageLabel } from '../lib/stages';

  interface TeamPanelInfo {
    team_name: string;
    elo: number;
    elo_cycle_start: number;
    avg_goals_scored: number;
    avg_goals_conceded: number;
    matches_played: number;
    wins: number;
    draws: number;
    losses: number;
    form_last_five: string;
    form_trend: string;
    data_source: string;
    flag: string | null;
  }

  interface PredictionVerdict {
    hit: boolean;
    predicted_home: number;
    predicted_away: number;
    real_outcome: 'home' | 'away' | 'draw';
    predicted_outcome: 'home' | 'away' | 'draw';
  }

  interface SidebarMatch {
    id: number;
    date: string;
    home_team: string;
    away_team: string;
    home_score: number | null;
    away_score: number | null;
    status: 'pending' | 'awaiting_teams' | 'finished';
    group_name: string | null;
    matchday: number | null;
    stage: string;
    has_cache: boolean;
    verdict: PredictionVerdict | null;
  }

  interface Prediction {
    probabilidades: {
      victoria_local: number;
      empate: number;
      victoria_visitante: number;
    };
    marcador_exacto: string;
    ganador_esperado: string;
    nivel_certeza: 'ALTA' | 'MEDIA' | 'BAJA';
    analisis: string;
    desglose_consenso: {
      simulacion_poisson: string;
      diferencial_elo: string;
      momento_forma_xg: string;
    };
  }

  const appData = JSON.parse(document.getElementById('app-data')!.textContent ?? '{}') as {
    teams: Record<string, TeamPanelInfo>;
    matches: SidebarMatch[];
  };

  const matchesById = new Map(appData.matches.map((match) => [match.id, match]));
  const emptyState = document.getElementById('empty-state') as HTMLDivElement;
  const analysisView = document.getElementById('analysis-view') as HTMLDivElement;
  const mainView = document.getElementById('main-view') as HTMLElement;

  function escapeHtml(value: string): string {
    const div = document.createElement('div');
    div.textContent = value;
    return div.innerHTML;
  }

  function flagMarkup(team: TeamPanelInfo | undefined, name: string): string {
    const flagUrl = team?.flag ?? getFlagUrl(name, 160);
    if (flagUrl) {
      return `<img class="flag-large" src="${escapeHtml(flagUrl)}" alt="Bandera de ${escapeHtml(name)}" />`;
    }
    return `<div class="flag-placeholder">${escapeHtml(name.slice(0, 2).toUpperCase())}</div>`;
  }

  function headerMarkup(match: SidebarMatch, centerHtml: string): string {
    const home = appData.teams[match.home_team];
    const away = appData.teams[match.away_team];
    return `
      <header class="matchup-header">
        <div class="team-side">
          ${flagMarkup(home, match.home_team)}
          <h3>${escapeHtml(match.home_team)}</h3>
        </div>
        <div class="center-block">${centerHtml}</div>
        <div class="team-side">
          ${flagMarkup(away, match.away_team)}
          <h3>${escapeHtml(match.away_team)}</h3>
        </div>
      </header>
    `;
  }

  function probBarMarkup(match: SidebarMatch, prediction: Prediction): string {
    const { victoria_local, empate, victoria_visitante } = prediction.probabilidades;
    const segment = (kind: string, value: number, label: string): string =>
      `<div class="prob-segment ${kind}" style="width:${value}%" title="${escapeHtml(label)}: ${value}%">${value >= 12 ? `${value}%` : ''}</div>`;

    return `
      <h4 class="section-title">Probabilidades del consenso</h4>
      <div class="prob-bar">
        ${segment('home', victoria_local, `Victoria ${match.home_team}`)}
        ${segment('draw', empate, 'Empate')}
        ${segment('away', victoria_visitante, `Victoria ${match.away_team}`)}
      </div>
      <div class="prob-legend">
        <span class="legend-item"><span class="legend-swatch home"></span>${escapeHtml(match.home_team)} ${victoria_local}%</span>
        <span class="legend-item"><span class="legend-swatch draw"></span>Empate ${empate}%</span>
        <span class="legend-item"><span class="legend-swatch away"></span>${escapeHtml(match.away_team)} ${victoria_visitante}%</span>
      </div>
    `;
  }

  function statsRow(
    label: string,
    homeValue: string,
    awayValue: string,
    leader: 'home' | 'away' | null
  ): string {
    return `
      <tr>
        <td class="value ${leader === 'home' ? 'leading' : ''}">${escapeHtml(homeValue)}</td>
        <td class="metric-label">${escapeHtml(label)}</td>
        <td class="value ${leader === 'away' ? 'leading' : ''}">${escapeHtml(awayValue)}</td>
      </tr>
    `;
  }

  function numericLeader(home: number, away: number, higherWins: boolean): 'home' | 'away' | null {
    if (home === away) {
      return null;
    }
    const homeLeads = higherWins ? home > away : home < away;
    return homeLeads ? 'home' : 'away';
  }

  function statsTableMarkup(match: SidebarMatch): string {
    const home = appData.teams[match.home_team];
    const away = appData.teams[match.away_team];

    if (!home || !away) {
      return '';
    }

    const sourceLabel = home.data_source === 'real' && away.data_source === 'real'
      ? 'Datos reales del ciclo 2022–2026'
      : 'Datos del ciclo 2022–2026';

    return `
      <h4 class="section-title">Cara a cara · ${escapeHtml(sourceLabel)}</h4>
      <table class="stats-table">
        <tbody>
          ${statsRow('Elo actual', String(home.elo), String(away.elo), numericLeader(home.elo, away.elo, true))}
          ${statsRow('Elo inicio de ciclo', String(home.elo_cycle_start), String(away.elo_cycle_start), numericLeader(home.elo_cycle_start, away.elo_cycle_start, true))}
          ${statsRow('Partidos jugados', String(home.matches_played), String(away.matches_played), null)}
          ${statsRow('Récord V-E-D', `${home.wins}-${home.draws}-${home.losses}`, `${away.wins}-${away.draws}-${away.losses}`, numericLeader(home.wins, away.wins, true))}
          ${statsRow('Goles a favor / partido', home.avg_goals_scored.toFixed(2), away.avg_goals_scored.toFixed(2), numericLeader(home.avg_goals_scored, away.avg_goals_scored, true))}
          ${statsRow('Goles en contra / partido', home.avg_goals_conceded.toFixed(2), away.avg_goals_conceded.toFixed(2), numericLeader(home.avg_goals_conceded, away.avg_goals_conceded, false))}
          ${statsRow('Forma (últimos 5)', home.form_last_five, away.form_last_five, null)}
          ${statsRow('Tendencia', home.form_trend, away.form_trend, null)}
        </tbody>
      </table>
    `;
  }

  function predictionMarkup(match: SidebarMatch, prediction: Prediction, cached: boolean): string {
    const center = `
      <span class="score-caption">Marcador predicho</span>
      <span class="predicted-score">${escapeHtml(prediction.marcador_exacto.replace('-', ' – '))}</span>
      <div class="meta-chips">
        <span class="chip">Ganador: ${escapeHtml(prediction.ganador_esperado)}</span>
        <span class="chip certainty-${escapeHtml(prediction.nivel_certeza)}">Certeza ${escapeHtml(prediction.nivel_certeza)}</span>
        <span class="chip">${cached ? 'Instantáneo · caché' : 'Recién generado'}</span>
      </div>
    `;

    return `
      ${headerMarkup(match, center)}
      ${probBarMarkup(match, prediction)}
      ${statsTableMarkup(match)}
      <h4 class="section-title">Síntesis del consenso</h4>
      <p class="analysis-block">${escapeHtml(prediction.analisis)}</p>
      <h4 class="section-title">Desglose por metodología</h4>
      <ul class="consensus-list">
        <li><strong>Simulación de Poisson</strong>${escapeHtml(prediction.desglose_consenso.simulacion_poisson)}</li>
        <li><strong>Diferencial Elo</strong>${escapeHtml(prediction.desglose_consenso.diferencial_elo)}</li>
        <li><strong>Momento de Forma / xG</strong>${escapeHtml(prediction.desglose_consenso.momento_forma_xg)}</li>
      </ul>
    `;
  }

  function awaitingMarkup(match: SidebarMatch): string {
    const center = `
      <span class="score-caption">${escapeHtml(stageLabel(match.stage))}</span>
      <span class="predicted-score">VS</span>
      <div class="meta-chips"><span class="chip">Llave pendiente por definir</span></div>
    `;

    return `
      ${headerMarkup(match, center)}
      <p class="finished-note">Las selecciones de esta llave aún no están definidas. Cuando se resuelva la fase previa y ambos equipos sean reales, la predicción con IA se habilitará automáticamente.</p>
    `;
  }

  function finishedMarkup(match: SidebarMatch): string {
    const verdict = match.verdict;
    const verdictChip = verdict
      ? `<span class="chip ${verdict.hit ? 'verdict-hit' : 'verdict-miss'}">${verdict.hit ? '🎯 Acierto de la IA' : '❌ Fallo de la IA'}</span>`
      : '';
    const predictedLine = verdict
      ? `<span class="ia-predicted">La IA predijo ${verdict.predicted_home} – ${verdict.predicted_away}</span>`
      : '';
    const note = verdict
      ? `Este partido ya terminó: la IA ${verdict.hit ? 'acertó' : 'falló'} el ganador (predijo ${verdict.predicted_home}-${verdict.predicted_away} y el resultado oficial fue ${match.home_score}-${match.away_score}).`
      : 'Este partido ya terminó: se muestra el resultado oficial y el cara a cara del ciclo.';
    const center = `
      <span class="score-caption">Resultado final</span>
      <span class="predicted-score">${match.home_score} – ${match.away_score}</span>
      ${predictedLine}
      <div class="meta-chips">
        <span class="chip">Partido finalizado</span>
        ${verdictChip}
      </div>
    `;

    return `
      ${headerMarkup(match, center)}
      ${statsTableMarkup(match)}
      <p class="finished-note">${note}</p>
    `;
  }

  function showAnalysis(html: string): void {
    emptyState.hidden = true;
    analysisView.hidden = false;
    analysisView.innerHTML = html;
    mainView.scrollTop = 0;
  }

  function showLoading(match: SidebarMatch): void {
    showAnalysis(`
      <div class="loading-state">
        <div class="spinner"></div>
        <p>Ejecutando motor determinista y consenso para ${escapeHtml(match.home_team)} vs ${escapeHtml(match.away_team)}…</p>
      </div>
    `);
  }

  async function selectMatch(matchId: number): Promise<void> {
    const match = matchesById.get(matchId);

    if (!match) {
      return;
    }

    document.querySelectorAll('.match-item.selected').forEach((item) => item.classList.remove('selected'));
    document.querySelector(`.match-item[data-match-id="${matchId}"]`)?.classList.add('selected');

    if (match.status === 'finished') {
      showAnalysis(finishedMarkup(match));
      return;
    }

    if (match.status === 'awaiting_teams') {
      showAnalysis(awaitingMarkup(match));
      return;
    }

    showLoading(match);

    try {
      const response = await fetch('/api/predict', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ matchId })
      });

      const payload = await response.json();

      if (!response.ok) {
        showAnalysis(`<div class="analysis-error">${escapeHtml(payload?.error ?? 'No fue posible generar la predicción.')}</div>`);
        return;
      }

      showAnalysis(predictionMarkup(match, payload.prediction as Prediction, Boolean(payload.cached)));
    } catch {
      showAnalysis('<div class="analysis-error">Error de red al solicitar la predicción.</div>');
    }
  }

  document.querySelectorAll<HTMLButtonElement>('.match-item').forEach((button) => {
    button.addEventListener('click', () => {
      void selectMatch(Number(button.dataset.matchId));
    });
  });
</script>
