---
import Layout from '../layouts/Layout.astro';
import { getCalendar, type Match } from '../lib/matches';
import { supabase } from '../lib/supabase';
import { getFlagUrl } from '../lib/flags';
import { stageShortLabel } from '../lib/stages';
import { evaluatePrediction } from '../lib/accuracy';

export const prerender = false;

interface TeamPanelInfo {
  team_name: string;
  elo: number;
  elo_cycle_start: number;
  avg_goals_scored: number;
  avg_goals_conceded: number;
  matches_played: number;
  wins: number;
  draws: number;
  losses: number;
  form_last_five: string;
  form_trend: string;
  data_source: string;
  flag: string | null;
}

let matches: Match[] = [];
let loadError: string | null = null;
const teams: Record<string, TeamPanelInfo> = {};

try {
  matches = await getCalendar();

  const { data, error } = await supabase
    .from('team_stats')
    .select(
      'team_name, eloratings_team_name, elo, elo_cycle_start, avg_goals_scored, avg_goals_conceded, matches_played, wins, draws, losses, form_last_five, form_trend, data_source'
    );

  if (error) {
    throw new Error(`Error al consultar las estadísticas: ${error.message}`);
  }

  for (const row of data ?? []) {
    teams[row.team_name] = {
      team_name: row.team_name,
      elo: row.elo,
      elo_cycle_start: row.elo_cycle_start,
      avg_goals_scored: Number(row.avg_goals_scored),
      avg_goals_conceded: Number(row.avg_goals_conceded),
      matches_played: row.matches_played,
      wins: row.wins,
      draws: row.draws,
      losses: row.losses,
      form_last_five: row.form_last_five,
      form_trend: row.form_trend,
      data_source: row.data_source,
      flag: row.eloratings_team_name ? getFlagUrl(row.eloratings_team_name, 160) : null
    };
  }
} catch (error) {
  loadError = error instanceof Error ? error.message : 'Error desconocido al cargar los datos.';
}

const flagFor = (teamName: string): string | null =>
  teams[teamName]?.flag ?? getFlagUrl(teamName, 160);

const dateFormatter = new Intl.DateTimeFormat('es-ES', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  timeZone: 'UTC'
});

const timeFormatter = new Intl.DateTimeFormat('es-ES', {
  hour: '2-digit',
  minute: '2-digit',
  timeZone: 'UTC'
});

const matchesByDay = new Map<string, Match[]>();

for (const match of matches) {
  const dayKey = dateFormatter.format(new Date(match.date));
  const dayMatches = matchesByDay.get(dayKey) ?? [];
  dayMatches.push(match);
  matchesByDay.set(dayKey, dayMatches);
}

const clientPayload = {
  teams,
  matches: matches.map((match) => ({
    id: match.id,
    date: match.date,
    home_team: match.home_team,
    away_team: match.away_team,
    home_score: match.home_score,
    away_score: match.away_score,
    status: match.status,
    group_name: match.group_name,
    matchday: match.matchday,
    stage: match.stage,
    has_cache: Boolean(match.prediction_cache),
    verdict: evaluatePrediction(match)
  }))
};
---

<Layout title="Mundial 2026 · Predicciones IA">
  <div class="app-shell">
    <aside class="sidebar glass-panel">
      <header class="sidebar-header">
        <p class="kicker">Copa Mundial FIFA 2026</p>
        <h1>Calendario Completo</h1>
      </header>

      {loadError && <div class="error-banner">{loadError}</div>}

      <div class="match-list">
        {
          [...matchesByDay.entries()].map(([day, dayMatches]) => (
            <section class="day-block">
              <h2 class="day-label">{day}</h2>
              {dayMatches.map((match) => {
                const homeFlag = flagFor(match.home_team);
                const awayFlag = flagFor(match.away_team);
                const verdict = evaluatePrediction(match);
                return (
                  <button
                    class="match-item"
                    type="button"
                    data-match-id={match.id}
                    aria-label={`Analizar ${match.home_team} contra ${match.away_team}`}
                  >
                    <span class="match-time">{timeFormatter.format(new Date(match.date))}</span>
                    <span class="match-teams">
                      <span class="match-row">
                        {homeFlag && <img class="flag-mini" src={homeFlag} alt="" loading="lazy" />}
                        <span>{match.home_team}</span>
                        {match.status === 'finished' && <strong class="mini-score">{match.home_score}</strong>}
                      </span>
                      <span class="match-row">
                        {awayFlag && <img class="flag-mini" src={awayFlag} alt="" loading="lazy" />}
                        <span>{match.away_team}</span>
                        {match.status === 'finished' && <strong class="mini-score">{match.away_score}</strong>}
                      </span>
                    </span>
                    <span class="match-meta">
                      <span class="group-chip">{match.group_name ?? stageShortLabel(match.stage)}</span>
                      {verdict && (
                        <span class={`verdict-badge ${verdict.hit ? 'hit' : 'miss'}`}>
                          {verdict.hit ? '🎯 Acierto' : '❌ Fallo'}
                        </span>
                      )}
                      {verdict && (
                        <span class="ia-score" title="Marcador predicho por la IA">
                          IA {verdict.predicted_home}-{verdict.predicted_away}
                        </span>
                      )}
                      {match.prediction_cache && <span class="cache-dot" title="Predicción en caché"></span>}
                    </span>
                  </button>
                );
              })}
            </section>
          ))
        }
      </div>
    </aside>

    <main class="main-view glass-panel" id="main-view">
      <div class="empty-state" id="empty-state">
        <div class="empty-orb"></div>
        <h2>Selecciona un partido</h2>
        <p>
          Elige un encuentro del calendario para ver la predicción del motor de consenso, las
          probabilidades y el cara a cara estadístico del ciclo 2022–2026.
        </p>
      </div>
      <div id="analysis-view" hidden></div>
    </main>
  </div>

  <script is:inline type="application/json" id="app-data" set:html={JSON.stringify(clientPayload)} />
</Layout>

<style>
  .app-shell {
    display: grid;
    grid-template-columns: 350px 1fr;
    gap: 1.5rem;
    max-width: 1400px;
    margin: 2rem auto 0;
    padding: 0 1.5rem 1.5rem;
    height: calc(100vh - 120px);
  }

  .glass-panel {
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: 24px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      0 18px 50px rgba(0, 0, 0, 0.3);
  }

  .sidebar {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .sidebar-header {
    padding: 1.5rem 1.5rem 1.25rem;
    border-bottom: 1px solid var(--glass-border);
  }

  .kicker {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--accent-home);
    font-weight: 700;
  }

  .sidebar-header h1 {
    font-size: 1.45rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    margin-top: 0.3rem;
    background: linear-gradient(to right, #ffffff, #94a3b8);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .error-banner {
    margin: 1rem 1.25rem 0;
    border: 1px solid rgba(255, 120, 120, 0.4);
    background: rgba(255, 120, 120, 0.08);
    border-radius: 10px;
    padding: 0.8rem 1rem;
    font-size: 0.85rem;
  }

  .match-list {
    flex: 1;
    overflow-y: auto;
    padding: 0.75rem;
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.18) transparent;
  }

  .day-block {
    margin-bottom: 1rem;
  }

  .day-label {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: capitalize;
    letter-spacing: 0.08em;
    color: var(--text-faint);
    padding: 0.4rem 0.5rem;
  }

  .match-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    text-align: left;
    padding: 0.75rem 1rem;
    margin-bottom: 0.5rem;
    border-radius: 16px;
    border: 1px solid transparent;
    background: rgba(255, 255, 255, 0.02);
    color: var(--text-primary);
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .match-item:hover {
    background: var(--glass-bg-strong);
    border-color: var(--glass-border-bright);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }

  .match-item.selected {
    background: var(--glass-bg-strong);
    border-color: var(--accent-home);
    box-shadow: 0 0 0 1px var(--accent-home), 0 8px 24px rgba(0, 0, 0, 0.2);
  }

  .match-time {
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
    color: var(--text-muted);
  }

  .match-teams {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.84rem;
    font-weight: 600;
  }

  .match-row {
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .mini-score {
    margin-left: auto;
    font-variant-numeric: tabular-nums;
  }

  .flag-mini {
    width: 1.15rem;
    height: 1.15rem;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--glass-border);
  }

  .match-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.35rem;
  }

  .group-chip {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0.18rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--glass-border);
    color: var(--text-muted);
  }

  .cache-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: rgba(110, 231, 183, 0.9);
    box-shadow: 0 0 8px rgba(110, 231, 183, 0.6);
  }

  .verdict-badge {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    white-space: nowrap;
    padding: 0.18rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--glass-border);
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    color: var(--text-muted);
  }

  .verdict-badge.hit {
    border-color: rgba(110, 231, 183, 0.45);
    background: rgba(110, 231, 183, 0.07);
    color: rgba(170, 255, 210, 0.95);
  }

  .verdict-badge.miss {
    border-color: rgba(255, 150, 140, 0.45);
    background: rgba(255, 140, 130, 0.06);
    color: rgba(255, 180, 170, 0.95);
  }

  .ia-score {
    font-size: 0.6rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.05em;
    color: var(--text-faint);
  }

  .main-view {
    overflow-y: auto;
    padding: 2rem;
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.18) transparent;
  }

  #analysis-view {
    min-height: 100%;
    display: flex;
    flex-direction: column;
  }

  .empty-state {
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1rem;
    color: var(--text-muted);
  }

  .empty-orb {
    width: 6.5rem;
    height: 6.5rem;
    border-radius: 50%;
    border: 1px solid var(--glass-border-bright);
    background:
      radial-gradient(circle at 30% 30%, rgba(96, 165, 250, 0.4), transparent 60%),
      radial-gradient(circle at 70% 70%, rgba(244, 114, 182, 0.4), transparent 60%);
    backdrop-filter: var(--glass-blur);
    box-shadow: 
      inset 0 1px 0 rgba(255, 255, 255, 0.2),
      0 0 40px rgba(96, 165, 250, 0.2);
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .empty-state h2 {
    font-size: 1.3rem;
    color: var(--text-primary);
  }

  .empty-state p {
    max-width: 420px;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .app-shell {
      grid-template-columns: 1fr;
      height: auto;
    }

