    font-weight: 600;
    padding: 0.28rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    color: var(--text-muted);
  }

  .chip.certainty-ALTA {
    border-color: rgba(110, 231, 183, 0.45);
