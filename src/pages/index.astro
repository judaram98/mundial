    width: 88px;
    height: 88px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--glass-border-bright);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.2),
      0 10px 30px rgba(0, 0, 0, 0.45);
  }

  .flag-placeholder {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
