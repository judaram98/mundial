    border-color: rgba(255, 220, 140, 0.45);
    color: rgba(255, 230, 170, 0.95);
  }

  .chip.certainty-BAJA {
    border-color: rgba(255, 150, 140, 0.45);
    color: rgba(255, 180, 170, 0.95);
  }

  .section-title {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
